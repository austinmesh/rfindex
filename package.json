    "ajv": "^8.18.0",
    "decap-server": "^3.0.0",
    "postcss": "^8",
    "sanitize-html": "^2.17.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "wrangler": "^4.107.0"
